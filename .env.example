NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/eclick_db

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Email — Sprint EM-1 multi-tenant. Cada org configura provider+key próprios
# em /dashboard/configuracoes/integracoes#email; backend só precisa da chave
# de derivação pra criptografar/decriptar via AES-256-CBC. Sem ENCRYPTION_KEY,
# email_settings.save/get falham com 400 e o EmailSender retorna no-op.
# Gere com: openssl rand -base64 32
ENCRYPTION_KEY=base64-string-de-32-bytes-aleatorios
